{
  "info": {
    "_postman_id": "4c962cdb-9b08-40c7-b607-afbf74d1792d",
    "name": "Todo Nest Backend",
    "description": "Collection for the Todo Nest backend. Run Register or Login first; either request saves the access token for protected todo endpoints. All API responses use the statusCode, success, message, and data envelope.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:7000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "todoId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('returns a successful authentication response', () => {",
                  "  pm.expect(response.success).to.eql(true);",
                  "  pm.expect(response.data.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('accessToken', response.data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Example User\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Registers a user and stores the returned JWT in the accessToken collection variable. Email must be unique; password must contain at least 6 characters."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('returns a successful authentication response', () => {",
                  "  pm.expect(response.success).to.eql(true);",
                  "  pm.expect(response.data.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('accessToken', response.data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Logs in and stores the returned JWT in the accessToken collection variable."
          }
        }
      ]
    },
    {
      "name": "Application",
      "item": [
        {
          "name": "Welcome",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('returns the welcome message', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.success).to.eql(true);",
                  "  pm.expect(response.data).to.eql('Welcome to the Todo Nest Backend!');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/",
            "description": "Returns the Todo Nest Backend welcome message."
          }
        }
      ]
    },

    {
      "name": "Todos",
      "item": [
        {
          "name": "Create Todo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('returns a created todo', () => {",
                  "  pm.expect(response.success).to.eql(true);",
                  "  pm.expect(response.data._id).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('todoId', response.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries\",\n  \"completed\": false\n}"
            },
            "url": "{{baseUrl}}/todos",
            "description": "Creates a todo for the authenticated user and saves its id in todoId."
          }
        },
        {
          "name": "List Todos",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/todos"
          }
        },
        {
          "name": "Get Todo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/todos/{{todoId}}"
          }
        },
        {
          "name": "Update Todo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy groceries and cook dinner\",\n  \"completed\": true\n}"
            },
            "url": "{{baseUrl}}/todos/{{todoId}}"
          }
        },
        {
          "name": "Delete Todo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/todos/{{todoId}}"
          }
        }
      ]
    }
  ]
}
